{
  "text": {
    "fontFamily": {
      "$value": "Inter",
      "$type": "fontFamily"
    },
    "color": {
      "primary": {
        "$value": "{figma.color.text.default}",
        "$type": "color"
      },
      "secondary": {
        "$value": "{figma.color.text.secondary.default}",
        "$type": "color"
      },
      "tertiary": {
        "$value": "{figma.color.text.tertiary.default}",
        "$type": "color"
      },
      "inverse": {
        "$value": "{figma.color.text.oninverse}",
        "$type": "color"
      }
    },
    "fontWeight": {
      "medium": {
        "$value": "{font.weight.medium}",
        "$type": "fontWeight"
      },
      "bold": {
        "$value": "{font.weight.bold}",
        "$type": "fontWeight"
      }
    },
    "default": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.fontFamily}",
        "fontSize": "{font.size.small}",
        "fontWeight": "{font.weight.medium}",
        "lineHeight": "{font.lineHeight.default}",
        "letterSpacing": "{font.letterSpacing.pos.large}"
      }
    },
    "styles": {
      "default": {
        "fontFamily": {
          "$value": "Inter",
          "$type": "string"
        },
        "fontSize": {
          "$value": "{text.default.fontSize}",
          "$type": "dimension"
        },
        "fontWeight": {
          "$value": "{text.default.fontWeight}",
          "$type": "number"
        },
        "lineHeight": {
          "$value": "{text.default.lineHeight}",
          "$type": "dimension"
        },
        "letterSpacing": {
          "$value": "{text.default.letterSpacing}",
          "$type": "dimension"
        }
      },
      "small": {
        "fontFamily": {
          "$value": "Inter",
          "$type": "string"
        },
        "fontSize": {
          "$value": "{font.size.small}",
          "$type": "dimension"
        },
        "fontWeight": {
          "$value": "{font.weight.medium}",
          "$type": "number"
        },
        "lineHeight": {
          "$value": "{font.lineHeight.default}",
          "$type": "dimension"
        },
        "letterSpacing": {
          "$value": "{font.letterSpacing.pos.large}",
          "$type": "dimension"
        }
      },
      "large": {
        "fontFamily": {
          "$value": "Inter",
          "$type": "string"
        },
        "fontSize": {
          "$value": "{font.size.medium}",
          "$type": "dimension"
        },
        "fontWeight": {
          "$value": "{font.weight.medium}",
          "$type": "number"
        },
        "lineHeight": {
          "$value": "{font.lineHeight.large}",
          "$type": "dimension"
        },
        "letterSpacing": {
          "$value": "{font.letterSpacing.pos.medium}",
          "$type": "dimension"
        }
      },
      "xlarge": {
        "fontFamily": {
          "$value": "Inter",
          "$type": "string"
        },
        "fontSize": {
          "$value": "{font.size.large}",
          "$type": "dimension"
        },
        "fontWeight": {
          "$value": "{font.weight.medium}",
          "$type": "number"
        },
        "lineHeight": {
          "$value": "{font.lineHeight.large}",
          "$type": "dimension"
        },
        "letterSpacing": {
          "$value": "{font.letterSpacing.pos.small}",
          "$type": "dimension"
        }
      }
    },
    "small": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.small.fontFamily}",
        "fontSize": "{text.styles.small.fontSize}",
        "fontWeight": "{text.styles.small.fontWeight}",
        "lineHeight": "{text.styles.small.lineHeight}",
        "letterSpacing": "{text.styles.small.letterSpacing}"
      }
    },
    "large": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.large.fontFamily}",
        "fontSize": "{text.styles.large.fontSize}",
        "fontWeight": "{text.styles.large.fontWeight}",
        "lineHeight": "{text.styles.large.lineHeight}",
        "letterSpacing": "{text.styles.large.letterSpacing}"
      }
    },
    "xlarge": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.styles.xlarge.fontFamily}",
        "fontSize": "{text.styles.xlarge.fontSize}",
        "fontWeight": "{text.styles.xlarge.fontWeight}",
        "lineHeight": "{text.styles.xlarge.lineHeight}",
        "letterSpacing": "{text.styles.xlarge.letterSpacing}"
      }
    },
    "link": {
      "$value": {
        "fontFamily": "{text.styles.small.fontFamily}",
        "fontSize": "{font.size.small}",
        "fontWeight": "{font.weight.normal}",
        "lineHeight": "{font.lineHeight.default}",
        "letterSpacing": "{font.letterSpacing.pos.large}",
        "textDecoration": "underline"
      },
      "color": {
        "$value": "{figma.color.text.brand.default}",
        "$type": "color"
      },
      "decoration": {
        "$value": "none",
        "$type": "string"
      },
      "borderFocus": {
        "$value": "none",
        "$type": "string"
      },
      "decorationFocus": {
        "$value": "underline",
        "$type": "string"
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{text.fontFamily}",
        "fontSize": "{text.styles.default.fontSize}",
        "fontWeight": "{text.styles.default.fontWeight}",
        "lineHeight": "{text.styles.default.lineHeight}",
        "letterSpacing": "{text.styles.default.letterSpacing}"
      },
      "color": {
        "$value": "{figma.color.text.tertiary.default}",
        "$type": "color"
      },
      "height": {
        "$value": "{size.pos.medium}",
        "$type": "dimension"
      },
      "padding": {
        "top": {
          "$value": "{size.null}",
          "$type": "dimension"
        },
        "right": {
          "$value": "{size.pos.xxxsmall}",
          "$type": "dimension"
        },
        "bottom": {
          "$value": "{size.null}",
          "$type": "dimension"
        },
        "left": {
          "$value": "{size.pos.xxsmall}",
          "$type": "dimension"
        }
      },
      "gap": {
        "$value": "{size.pos.xxxsmall}",
        "$type": "dimension"
      }
    }
  }
}
